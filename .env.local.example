# ── Supabase ──────────────────────────────────────────────────────────────────
# Project URL : find in Supabase : Settings : API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co

# Anon/public key : safe to expose in the browser
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Service role key : NEVER expose in the browser, server-side only
# Used by: lib/supabase/admin.ts (public Prove profiles, partner stats)
# Find in: Supabase : Settings : API : service_role
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Database password : used only by scripts/run-schema.mjs to apply migrations
# Find in: Supabase : Settings : Database : Database password
SUPABASE_DB_PASSWORD=your-database-password

# ── Stripe ────────────────────────────────────────────────────────────────────
# Secret key : server-side only
STRIPE_SECRET_KEY=sk_live_...

# Webhook signing secret : from Stripe : Webhooks : your endpoint : Signing secret
STRIPE_WEBHOOK_SECRET=whsec_...

# Existing Stripe price ID for lomoura Pro
STRIPE_PRO_PRICE_ID=price_...

# ── Email (Resend) ────────────────────────────────────────────────────────────
RESEND_API_KEY=re_...
RESEND_FROM_EMAIL=lomoura <noreply@lomoura.com>

# ── App ───────────────────────────────────────────────────────────────────────
# Public URL of your deployment (used for OG images and share links)
NEXT_PUBLIC_APP_URL=https://your-domain.com

# Google OAuth web client ID
NEXT_PUBLIC_GOOGLE_CLIENT_ID=802068967492-e1hhc3raci569l65of33pv8794u00q9q.apps.googleusercontent.com

# Vercel Cron bearer secret
CRON_SECRET=generate-a-long-random-secret
